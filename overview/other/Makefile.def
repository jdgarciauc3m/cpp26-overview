OVERVIEW_OTHER_BASE=other
OVERVIEW_OTHER_DIR=$(OVERVIEW_DIR)/$(OVERVIEW_OTHER_BASE)
OVERVIEW_OTHER_PARTS= \
	$(OVERVIEW_OTHER_DIR)/*.tex

OVERVIEW_PARTS += $(OVERVIEW_OTHER_PARTS)

OVERVIEW_OTHER_PDF=$(OVERVIEW_DIR)-$(OVERVIEW_OTHER_BASE).pdf
OVERVIEW_OTHER_DOCX=$(OVERVIEW_DIR)-$(OVERVIEW_OTHER_BASE).docx

FINAL_OVERVIEW_OTHER_PDF=$(FINAL_DIR)/$(OVERVIEW_OTHER_PDF)
FINAL_OVERVIEW_OTHER_DOCX=$(FINAL_DIR)/$(OVERVIEW_OTHER_DOCX)

ALL_SLIDES_FINAL_PDF += \
	$(FINAL_OVERVIEW_OTHER_PDF)