OVERVIEW_SENDRECV_BASE=sendrecv
OVERVIEW_SENDRECV_DIR=$(OVERVIEW_DIR)/$(OVERVIEW_SENDRECV_BASE)
OVERVIEW_SENDRECV_PARTS= \
	$(OVERVIEW_SENDRECV_DIR)/*.tex

OVERVIEW_PARTS += $(OVERVIEW_SENDRECV_PARTS)

OVERVIEW_SENDRECV_PDF=$(OVERVIEW_DIR)-$(OVERVIEW_SENDRECV_BASE).pdf
OVERVIEW_SENDRECV_DOCX=$(OVERVIEW_DIR)-$(OVERVIEW_SENDRECV_BASE).docx

FINAL_OVERVIEW_SENDRECV_PDF=$(FINAL_DIR)/$(OVERVIEW_SENDRECV_PDF)
FINAL_OVERVIEW_SENDRECV_DOCX=$(FINAL_DIR)/$(OVERVIEW_SENDRECV_DOCX)

ALL_SLIDES_FINAL_PDF += \
	$(FINAL_OVERVIEW_SENDRECV_PDF)