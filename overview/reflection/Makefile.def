OVERVIEW_REFLECTION_BASE=reflection
OVERVIEW_REFLECTION_DIR=$(OVERVIEW_DIR)/$(OVERVIEW_REFLECTION_BASE)
OVERVIEW_REFLECTION_PARTS= \
	$(OVERVIEW_REFLECTION_DIR)/*.tex

OVERVIEW_PARTS += $(OVERVIEW_REFLECTION_PARTS)

OVERVIEW_REFLECTION_PDF=$(OVERVIEW_DIR)-$(OVERVIEW_REFLECTION_BASE).pdf
OVERVIEW_REFLECTION_DOCX=$(OVERVIEW_DIR)-$(OVERVIEW_REFLECTION_BASE).docx

FINAL_OVERVIEW_REFLECTION_PDF=$(FINAL_DIR)/$(OVERVIEW_REFLECTION_PDF)
FINAL_OVERVIEW_REFLECTION_DOCX=$(FINAL_DIR)/$(OVERVIEW_REFLECTION_DOCX)

ALL_SLIDES_FINAL_PDF += \
	$(FINAL_OVERVIEW_REFLECTION_PDF)