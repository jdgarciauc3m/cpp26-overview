OVERVIEW_INTRO_BASE=intro
OVERVIEW_INTRO_DIR=$(OVERVIEW_DIR)/$(OVERVIEW_INTRO_BASE)
OVERVIEW_INTRO_PARTS= \
	$(OVERVIEW_INTRO_DIR)/*.tex

OVERVIEW_PARTS += $(OVERVIEW_INTRO_PARTS)

OVERVIEW_INTRO_PDF=$(OVERVIEW_DIR)-$(OVERVIEW_INTRO_BASE).pdf
OVERVIEW_INTRO_DOCX=$(OVERVIEW_DIR)-$(OVERVIEW_INTRO_BASE).docx

FINAL_OVERVIEW_INTRO_PDF=$(FINAL_DIR)/$(OVERVIEW_INTRO_PDF)
FINAL_OVERVIEW_INTRO_DOCX=$(FINAL_DIR)/$(OVERVIEW_INTRO_DOCX)

ALL_SLIDES_FINAL_PDF += \
	$(FINAL_OVERVIEW_INTRO_PDF)