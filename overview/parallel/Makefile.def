OVERVIEW_PARALLEL_BASE=parallel
OVERVIEW_PARALLEL_DIR=$(OVERVIEW_DIR)/$(OVERVIEW_PARALLEL_BASE)
OVERVIEW_PARALLEL_PARTS= \
	$(OVERVIEW_PARALLEL_DIR)/*.tex

OVERVIEW_PARTS += $(OVERVIEW_PARALLEL_PARTS)

OVERVIEW_PARALLEL_PDF=$(OVERVIEW_DIR)-$(OVERVIEW_PARALLEL_BASE).pdf
OVERVIEW_PARALLEL_DOCX=$(OVERVIEW_DIR)-$(OVERVIEW_PARALLEL_BASE).docx

FINAL_OVERVIEW_PARALLEL_PDF=$(FINAL_DIR)/$(OVERVIEW_PARALLEL_PDF)
FINAL_OVERVIEW_PARALLEL_DOCX=$(FINAL_DIR)/$(OVERVIEW_PARALLEL_DOCX)

ALL_SLIDES_FINAL_PDF += \
	$(FINAL_OVERVIEW_PARALLEL_PDF)