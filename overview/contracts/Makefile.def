OVERVIEW_CONTRACTS_BASE=contracts
OVERVIEW_CONTRACTS_DIR=$(OVERVIEW_DIR)/$(OVERVIEW_CONTRACTS_BASE)
OVERVIEW_CONTRACTS_PARTS= \
	$(OVERVIEW_CONTRACTS_DIR)/*.tex

OVERVIEW_PARTS += $(OVERVIEW_CONTRACTS_PARTS)

OVERVIEW_CONTRACTS_PDF=$(OVERVIEW_DIR)-$(OVERVIEW_CONTRACTS_BASE).pdf
OVERVIEW_CONTRACTS_DOCX=$(OVERVIEW_DIR)-$(OVERVIEW_CONTRACTS_BASE).docx

FINAL_OVERVIEW_CONTRACTS_PDF=$(FINAL_DIR)/$(OVERVIEW_CONTRACTS_PDF)
FINAL_OVERVIEW_CONTRACTS_DOCX=$(FINAL_DIR)/$(OVERVIEW_CONTRACTS_DOCX)

ALL_SLIDES_FINAL_PDF += \
	$(FINAL_OVERVIEW_CONTRACTS_PDF)