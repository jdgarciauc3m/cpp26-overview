OVERVIEW_SUMMARY_BASE=summary
OVERVIEW_SUMMARY_DIR=$(OVERVIEW_DIR)/$(OVERVIEW_SUMMARY_BASE)
OVERVIEW_SUMMARY_PARTS= \
	$(OVERVIEW_SUMMARY_DIR)/*.tex

OVERVIEW_PARTS += $(OVERVIEW_SUMMARY_PARTS)

OVERVIEW_SUMMARY_PDF=$(OVERVIEW_DIR)-$(OVERVIEW_SUMMARY_BASE).pdf
OVERVIEW_SUMMARY_DOCX=$(OVERVIEW_DIR)-$(OVERVIEW_SUMMARY_BASE).docx

FINAL_OVERVIEW_SUMMARY_PDF=$(FINAL_DIR)/$(OVERVIEW_SUMMARY_PDF)
FINAL_OVERVIEW_SUMMARY_DOCX=$(FINAL_DIR)/$(OVERVIEW_SUMMARY_DOCX)

ALL_SLIDES_FINAL_PDF += \
	$(FINAL_OVERVIEW_SUMMARY_PDF)