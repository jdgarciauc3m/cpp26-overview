OVERVIEW_UBSAFETY_BASE=ubsafety
OVERVIEW_UBSAFETY_DIR=$(OVERVIEW_DIR)/$(OVERVIEW_UBSAFETY_BASE)
OVERVIEW_UBSAFETY_PARTS= \
	$(OVERVIEW_UBSAFETY_DIR)/*.tex

OVERVIEW_PARTS += $(OVERVIEW_UBSAFETY_PARTS)

OVERVIEW_UBSAFETY_PDF=$(OVERVIEW_DIR)-$(OVERVIEW_UBSAFETY_BASE).pdf
OVERVIEW_UBSAFETY_DOCX=$(OVERVIEW_DIR)-$(OVERVIEW_UBSAFETY_BASE).docx

FINAL_OVERVIEW_UBSAFETY_PDF=$(FINAL_DIR)/$(OVERVIEW_UBSAFETY_PDF)
FINAL_OVERVIEW_UBSAFETY_DOCX=$(FINAL_DIR)/$(OVERVIEW_UBSAFETY_DOCX)

ALL_SLIDES_FINAL_PDF += \
	$(FINAL_OVERVIEW_UBSAFETY_PDF)